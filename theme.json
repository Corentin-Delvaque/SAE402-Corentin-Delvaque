{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
   "templateParts": [
    {
      "name": "header",
      "title": "En-tête",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Pied de page",
      "area": "footer"
    }
  ],
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "custom": false,
      "palette": [
        {
          "name": "Primary",
          "slug": "primary",
          "color": "#0073aa"
        },
        {
          "name": "Secondary",
          "slug": "secondary",
          "color": "#005177"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#d54e21"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Custom Font",
          "slug": "custom-font",
          "fontFace": [
            {
              "fontFamily": "Custom Font",
              "src": "url(../assets/fonts/custom-font.woff2) format('woff2')"
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--primary)",
      "text": "var(--wp--preset--color--secondary)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--typography--custom-font)"
    }
  }
}